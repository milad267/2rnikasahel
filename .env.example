# ============================================================================
# DSAHEL — محیط‌های ضروری (Required)
# ============================================================================

# Required in production
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
AUTH_SECRET=replace-with-at-least-32-random-characters
SETUP_TOKEN=replace-with-a-separate-random-install-token
TELEGRAM_WEBHOOK_SECRET=replace-with-a-random-telegram-webhook-secret
ADMIN_EMAIL=admin@example.com
ADMIN_PHONE=09120000000
ADMIN_PASSWORD=replace-with-a-strong-unique-password

# Optional: only when you intentionally want to log into the demo contractor account
DEMO_USER_PASSWORD=

# Public canonical URL, without a trailing slash
NEXT_PUBLIC_SITE_URL=https://example.com

# ============================================================================
# Runtime Settings (Optional)
# ============================================================================

# Server port (default: 3000)
PORT=3000

# Node environment
NODE_ENV=production

# Persistent uploads and chat attachments. Point this to a backed-up writable directory on the server.
APP_DATA_DIR=/var/lib/dornika

# Never enable this on a live store. It is only for staging payment tests.
PAYMENT_SANDBOX=false

# ============================================================================
# OpenAI / AI Settings (Optional - configure via admin panel)
# ============================================================================

# OPENAI_API_KEY=sk-...
# AI_PROVIDER=openai
# AI_MODEL=gpt-4o-mini

# ============================================================================
# Backup (Optional — uses APP_DATA_DIR/backups by default)
# ============================================================================

# BACKUP_RETENTION_DAYS=30

# Backup encryption key (optional but recommended). Must be exactly 32 bytes (64 hex chars).
# Generate with: openssl rand -hex 32
# If not set, backups are stored unencrypted (not recommended for production).
# BACKUP_ENCRYPTION_KEY=