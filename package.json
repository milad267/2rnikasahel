{
  "name": "nextjs-postgresql-template",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack -p 3000 -H 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "db:push": "drizzle-kit push --config=drizzle.config.json",
    "db:generate": "drizzle-kit generate --config=drizzle.config.json",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.json",
    "db:studio": "drizzle-kit studio --config=drizzle.config.json",
    "db:seed": "node scripts/seed.mjs",
    "db:seed-content": "node scripts/seed-content.mjs",
    "setup": "npm run db:push && npm run db:seed",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
